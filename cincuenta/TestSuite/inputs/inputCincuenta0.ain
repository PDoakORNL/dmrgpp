##Ainur1.0

FicticiousBeta=50;
# Because we're using U nup ndown
# the mu should be -0.5*U
ChemicalPotential=0.;
Matsubaras=400;
# LatticeGf: 50 is the number of K points
#LatticeGf="momentum,1D,50";
# Here 4 is the bandwidth W
LatticeGf="energy,semicircular,4";
NumberOfBathPoints=5;
DmftNumberOfIterations=1;
DmftTolerance=0.001;
ImpuritySolver="exactdiag";

#FitMethod=simplex;
#FitOptions=setonsitestozero;
MinParamsDelta=0.01;
MinParamsMaxIter=10000;
MinParamsDelta2=0.01;
MinParamsTolerance=1e-4;
MinParamsVerbose=1;

# Location of the impurity (must be 0 for now)
int ImpuritySite=0;

#Model params
real HubbardU=8.0;

# These solver options will be appended to the one that cincuenta uses
#SolverOptions="";
RootOutputname="MyCincuentaExactDiag";
InfiniteLoopKeptStates=100;
matrix FiniteLoopsGs=[[@auto, 300, 0],[@auto, 300, 0]];
matrix FiniteLoopsOmega=[[@auto, 300, 2],[@auto, 300, 2]];

TargetElectronsUp=3;
TargetElectronsDown=3;

# This is needed for the real freq. computation
real OmegaBegin=-6.;
integer OmegaTotal=120;
real OmegaStep=0.1;
real OmegaDelta=0.1;

# Optional below
integer TridiagSteps=400;
real TridiagEps=1e-9;
TruncationTolerance="1e-10,100";

CorrectionVectorEta=0.;
GsWeight=0.1;

