##Ainur1.0

# Near-atomic-limit hopping quench for GEBK Fig. 3, L=2 second bath.
#
# GEBK Fig. 3 parameters: U=2, 100 steps, dt=0.04 (tmax=4),
# atomic limit start (W_i~0), quench to Bethe bandwidth W_f=4 (t*=1).
#
# Approximation: W_i=0.1 (nearly atomic; Λ^- << Λ^+), step quench
# (cincuenta does not yet implement the cosine ramp tq=0.25 from GEBK).
#
# L=2: second bath rank 2.  For the plot to differ from L=0 the GBEK
# dispatch and prepareTimeStep wiring must be in place -- see cincuenta.cpp
# and NeqDmftSolver::timeStep.

FicticiousBeta=16;
ChemicalPotential=0.;
Matsubaras=200;
LatticeGf="energy,semicircular,0.1";
NumberOfBathPoints=5;

DmftNumberOfIterations=10;
DmftTolerance=0.001;
ImpuritySolver="exactdiag";

FitOptions=particleholesymmetric;
MinParamsDelta=0.01;
MinParamsMaxIter=10000;
MinParamsDelta2=0.01;
MinParamsTolerance=1e-3;
MinParamsVerbose=1;

TargetElectronsUp=3;
TargetElectronsDown=3;

int ImpuritySite=0;
real HubbardU=2.;

# DMRG settings (required by ParamsDmftSolver; unused for exactdiag)
RootOutputname="NeqGBEKFig3L2";
InfiniteLoopKeptStates=200;
matrix FiniteLoopsGs=[[@auto, 200, 0],[@auto, 200, 0]];

real OmegaBegin=-6.;
integer OmegaTotal=120;
real OmegaStep=0.1;
real OmegaDelta=0.1;

integer TridiagSteps=400;
real TridiagEps=1e-9;
TruncationTolerance="1e-10,100";
CorrectionVectorEta=0.;
GsWeight=0.1;

matrix FiniteLoopsOmega=[[@auto, 200, 2],[@auto, 200, 2]];

# Non-equilibrium: hopping quench W_i=0.1 -> W_f=4.  U=2 fixed.
HubbardUFinal=2.;
TmaxNeq=4.0;
NtNeq=100;

NeqDmftIter=3;
NeqDmftTolerance=1e-8;

# GBEK two-bath solver, second bath rank L=2
NeqSolver="gbek";
NeqBathRank=2;

# BandwidthFinal=4 -> t*_f = 1 -> tStarFinalSq_ = 1.
BandwidthFinal=4.;
QuenchShape="cosine";
QuenchDuration=0.25;

NeqOutputPrefix="gebk-fig3-L2";
