##Ainur1.0

# TotalNumberOfSites includes the bath sites and the impurity
TotalNumberOfSites=6;

# Location of the impurity (must be 0 for now)
ImpuritySite=0;
HubbardU=4.0;
#Model params
# These solver options will be appended to the one that cincuenta uses
SolverOptions="";
RootOutputname="MyCincuentaTest";
InfiniteLoopKeptStates=100;
FiniteLoops=[
[@auto, 300, 0],
[@auto, 300, 0]];
TargetElectronsUp=3;
TargetElectronsDown=3;
